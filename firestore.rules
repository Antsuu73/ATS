rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Bài tập — ai cũng đọc được
    match /problems/{problemId} {
      allow read: if true;
      allow write: if false;
    }

    // Hồ sơ + tiến độ người dùng
    match /users/{userId} {
      allow read, create, update: if isOwner(userId);
      allow delete: if false;

      match /solved/{problemId} {
        allow read, create, update: if isOwner(userId);
        allow delete: if false;
      }

      match /lessons/{lessonId} {
        allow read, create, update: if isOwner(userId);
        allow delete: if false;
      }
    }

    // Community — ai đọc được, thành viên đăng/chỉnh, xóa được bài của mình
    match /communityPosts/{postId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isOwner(resource.data.authorId);

      match /comments/{commentId} {
        allow read: if true;
        allow create: if isSignedIn();
        allow update, delete: if isOwner(resource.data.authorId);
      }
    }

    // Arena — bài tập tùy chỉnh do người dùng tạo
    match /customProblems/{problemId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
      allow update: if isSignedIn() && (
        resource.data.authorId == request.auth.uid ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(["solvedBy", "updatedAt"])
      );
      allow delete: if isOwner(resource.data.authorId);
    }
  }
}

function isOwner(userId) {
  return request.auth != null && request.auth.uid == userId;
}

function isSignedIn() {
  return request.auth != null;
}
